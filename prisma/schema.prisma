generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id           String   @id @default(uuid())
  name         String
  clientId     String   @unique
  clientSecret String
  redirectUrl  String
  createdAt    DateTime @default(now())

  ownerId String
  owner   User   @relation("UserOwnedApps", fields: [ownerId], references: [id])

  googleClientId     String?
  googleClientSecret String?
  googleRedirectUri  String?

  githubClientId     String?
  githubClientSecret String?
  githubRedirectUri  String?

  users User[] @relation("AppUsers")
}

model User {
  id         String   @id @default(uuid())
  email      String
  password   String?
  provider   String
  providerId String?
  createdAt  DateTime @default(now())

  appId       String
  application Application @relation("AppUsers", fields: [appId], references: [id])

  refreshTokens RefreshToken[]

  ownedApps Application[] @relation("UserOwnedApps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
