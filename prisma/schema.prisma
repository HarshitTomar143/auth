generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id             String   @id @default(uuid())
  name           String
  clientId       String   @unique
  clientSecret   String
  redirectUrl    String
  createdAt      DateTime @default(now())

  users          User[]
}

model User {
  id           String   @id @default(uuid())
  email        String
  password     String?
  provider     String   // local, google, github
  providerId   String?
  createdAt    DateTime @default(now())

  appId        String
  application  Application @relation(fields: [appId], references: [id])

  refreshTokens RefreshToken[]

  @@unique([email, appId]) // same email allowed in different apps
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}